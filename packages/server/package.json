{
  "name": "@sodazone/ocelloids-service-node",
  "version": "4.0.7-dev.0",
  "type": "module",
  "description": "Ocelloids Service Node",
  "author": "SO/DA <projects@soda.zone>",
  "contributors": [
    "Marc Fornós <marc@soda.zone>",
    "Xueying Wang <xueying@soda.zone>"
  ],
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "bin": {
    "oc-ingress": "./dist/services/ingress/server/main.js",
    "oc-node": "./dist/main.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "prod:build": "tsc -p tsconfig.prod.json && tsc-alias -p tsconfig.prod.json",
    "start": "tsx ./src/main.ts",
    "dev": "nodemon --exec tsx ./src/main.ts",
    "dev:inspect": "nodemon --exec tsx --inspect ./src/main.ts",
    "dev:ingress": "nodemon --exec tsx ./src/services/ingress/server/main.ts",
    "dev:exec": "nodemon --exec tsx ./src/main.ts --distributed",
    "lint": "biome check --write src/**/*.ts",
    "lint:fix": "biome check --fix --unsafe src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "license": "Apache-2.0",
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "4.1.3",
    "@vitest/ui": "4.1.3",
    "nock": "^14.0.12",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.4.1-r.5",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/websocket": "^11.2.0",
    "@polkadot-api/legacy-provider": "0.3.3",
    "@polkadot-api/tx-utils": "0.1.7",
    "@scalar/fastify-api-reference": "^1.51.0",
    "@types/better-sqlite3": "^7.6.13",
    "@wormhole-foundation/sdk-definitions": "^3.12.0",
    "async-mutex": "^0.5.0",
    "better-sqlite3": "^12.8.0",
    "bs58": "^6.0.0",
    "cbor-x": "^1.6.4",
    "close-with-grace": "^2.5.0",
    "commander": "^14.0.3",
    "destr": "^2.0.5",
    "dotenv": "^17.4.1",
    "fastify": "^5.8.4",
    "fastify-healthcheck": "^5.1.0",
    "fastify-plugin": "^5.1.0",
    "fzstd": "^0.1.1",
    "got": "^14.6.6",
    "handlebars": "^4.7.9",
    "ky": "^1.14.3",
    "kysely": "^0.28.15",
    "level": "^10.0.0",
    "lru-cache": "^11.3.2",
    "memory-level": "^3.1.0",
    "mingo": "^6.7.2",
    "p-limit": "^7.3.0",
    "p-queue": "^9.1.2",
    "pg": "^8.20.0",
    "polkadot-api": "1.20.0",
    "prom-client": "^15.1.3",
    "redis": "^5.11.0",
    "rfc6902": "^5.2.0",
    "rxjs": "^7.8.2",
    "telegraf": "^4.16.3",
    "toml": "^3.0.0",
    "ulidx": "^2.4.1",
    "viem": "^2.47.10",
    "ws": "^8.20.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "packageManager": "yarn@4.1.0",
  "stableVersion": "4.0.6"
}
